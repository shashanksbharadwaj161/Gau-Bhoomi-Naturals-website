DirectoryIndex index.html index.php

Options -MultiViews
RewriteEngine On
RewriteBase /

<Files wp-config.php>
  order allow,deny
  deny from all
</Files>

# WordPress admin — serve directly
RewriteRule ^wp-admin(/.*)?$ - [L]
RewriteRule ^wp-login\.php$ - [L]

# WordPress REST API — route to WordPress with the REST route preserved
# (?rest_route=/...), so wc/store and wc/v3 endpoints dispatch correctly
# regardless of permalink settings. The previous form dropped the route,
# which made the REST API 404 and forced the app onto mock data.
RewriteRule ^wp-json/(.+)$ /index.php?rest_route=/$1 [QSA,L]
RewriteRule ^wp-json/?$   /index.php?rest_route=/ [QSA,L]

# WordPress static files — serve directly
RewriteRule ^wp-content(/.*)?$ - [L]
RewriteRule ^wp-includes(/.*)?$ - [L]
RewriteRule ^wp-cron\.php$ - [L]
RewriteRule ^xmlrpc\.php$ - [L]

# React build assets — serve directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else → React SPA
RewriteRule ^ /index.html [QSA,L]

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
